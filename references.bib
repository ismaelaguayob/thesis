@incollection{sachweh_social_2016,
  title = {Social {{Justice}} and the {{Welfare State}}: {{Institutions}}, {{Outcomes}}, and {{Attitudes}} in {{Comparative Perspective}}},
  shorttitle = {Social {{Justice}} and the {{Welfare State}}},
  booktitle = {Handbook of {{Social Justice Theory}} and {{Research}}},
  author = {Sachweh, Patrick},
