@article{boltanski_sociology_1999,
  title = {The {{Sociology}} of {{Critical Capacity}}},
  author = {Boltanski, Luc and Th{\'e}venot, Laurent},
  year = 1999,
  month = aug,
  journal = {European Journal of Social Theory},
  volume = {2},
  number = {3},
  pages = {359--377},
  publisher = {SAGE Publications Ltd},
  issn = {1368-4310},
  doi = {10.1177/136843199002003010},
  urldate = {2026-04-16},
  abstract = {This article argues that many situations in social life can be analyzed by their requirement for the justification of action. It is in particular in situations of dispute that a need arises to explicate the grounds on which responsibility for errors is distributed and on which new agreement can be reached. Since a plurality of mutually incompatible modes of justification exists, disputes can be understood as disagreements either about whether the accepted rule of justification has not been violated or about which mode of justification to apply at all. The article develops a grammar of such modes of justification, called orders of worth (grandeur), and argues that the human capacity for criticism becomes visible in the daily occurrence of disputes over criteria for justification. At the same time, it is underlined that not all social situations can be interpreted with the help of such a sense of justice, which resides on a notion of equivalence. Regimes of love, of violence or of familiarity are systematically distinct from regimes of justification.},
  langid = {english},
  file = {/home/ismaelaguayob/Zotero/storage/PJQFMKRZ/Boltanski and Thévenot - 1999 - The Sociology of Critical Capacity.pdf}
}
