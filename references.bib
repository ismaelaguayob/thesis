@article{rozas-bugueno_challenging_2024,
  title = {Challenging the Policy Space: {{The}} Legitimation of Alternatives in {{Chilean}} Pension Policy (1980--2019)},
  shorttitle = {Challenging the Policy Space},
  author = {{Rozas-Bugue{\~n}o}, Joaqu{\'i}n and Maillet, Antoine},
  year = 2024,
  journal = {Latin American Policy},
