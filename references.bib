@article{gaffney_pathologically_2025,
  title = {The `Pathologically State Dependent' versus `Middle-Aged Ministers on Mammoth Salaries': {{The}} Legitimation Contest over a 2013 Austerity Measure in the {{Republic}} of {{Ireland}}},
  shorttitle = {The `Pathologically State Dependent' versus `Middle-Aged Ministers on Mammoth Salaries'},
  author = {Gaffney, Stephen},
  year = 2025,
  month = mar,
  journal = {Discourse \& Society},
  volume = {36},
  number = {2},
  pages = {180--195},
  publisher = {SAGE Publications Ltd},
  issn = {0957-9265},
  doi = {10.1177/09579265241266020},
  urldate = {2026-06-23},
  abstract = {This paper provides a discourse analysis of the political and media debate surrounding a 2013 austerity measure that targeted unemployed young people in the Republic of Ireland. Applying Van Leeuwen's `justificatory schema' it reveals the legitimation of this measure relied on an `anti-welfare populist' framing of the young unemployed as `welfare dependent' and thus `undeserving'. Furthermore, this analysis finds that those opposed to this austerity measure sought to de-legitimate it and to re-legitimate the young unemployed. At times by singling out alternative `undeserving' figures to be targeted with austerity in their place. This process thus remained open to contestation and resignification, albeit in a manner that failed to challenge the underlying political-economic logic at play. The antagonistic framings revealed by these findings complicate the emphasis on `de-politicisation' in the pre-existing literature using discourse analysis methods to investigate the legitimation of austerity.},
  langid = {english},
  file = {/home/ismaelaguayob/Zotero/storage/LH8RBGZ9/Gaffney - 2025 - The ‘pathologically state dependent’ versus ‘middle-aged ministers on mammoth salaries’ The legitim.pdf}
}
