@article{leifeld_reconceptualizing_2013,
  title = {Reconceptualizing {{Major Policy Change}} in the {{Advocacy Coalition Framework}}: {{A Discourse Network Analysis}} of {{German Pension Politics}}},
  shorttitle = {Reconceptualizing {{Major Policy Change}} in the {{Advocacy Coalition Framework}}},
  author = {Leifeld, Philip},
  year = 2013,
  journal = {Policy Studies Journal},
  volume = {41},
  number = {1},
  pages = {169--198},
  issn = {1541-0072},
  doi = {10.1111/psj.12007},
  urldate = {2026-04-21},
  abstract = {How does major policy change come about? This article identifies and rectifies weaknesses in the conceptualization of innovative policy change in the Advocacy Coalition Framework. In a case study of policy belief change preceding an innovative reform in the German subsystem of old-age security, important new aspects of major policy change are carved out. In particular, the analysis traces a transition from one single hegemonic advocacy coalition to another stable coalition, with a transition phase between the two equilibria. The transition phase is characterized (i) by a bipolarization of policy beliefs in the subsystem and (ii) by state actors with shifting coalition memberships due to policy learning across coalitions or due to executive turnover. Apparently, there are subsystems with specific characteristics (presumably redistributive rather than regulative subsystems) in which one hegemonic coalition is the default, or the ``normal state.'' In these subsystems, polarization and shifting coalition memberships seem to interact to produce coalition turnover and major policy change. The case study is based on discourse network analysis, a combination of qualitative content analysis and social network analysis, which provides an intertemporal measurement of advocacy coalition realignment at the level of policy beliefs in a subsystem.},
  copyright = {\copyright{} 2013 Policy Studies Organization},
  langid = {english},
  keywords = {Advocacy Coalition Framework,demographic change,discourse network analysis,Germany,old-age security,pension politics,polarization,policy change,policy debates,policy networks,political discourse},
  file = {/home/ismaelaguayob/Zotero/storage/9G36YRZG/Leifeld - 2013 - Reconceptualizing Major Policy Change in the Advocacy Coalition Framework A Discourse Network Analy.pdf;/home/ismaelaguayob/Zotero/storage/2GFX5CX7/psj.html}
}
