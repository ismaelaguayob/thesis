  shorttitle = {{El Sistema de Pensiones chileno posreforma 2025}},
  author = {Vela, Javiera},
  year = 2025,
  month = jul,
  journal = {Estudios P\'ublicos},
  pages = {1--45},
  issn = {0718-3089},
  doi = {10.38178/07183089/1157240905},
  urldate = {2025-08-26},
  abstract = {The article reviews the historical and conceptual background in order to determine whether the Chilean pension system, after the pension reform of 2025, can be described as a neoliberal pension model. It describes mandatory individual capitalization as its backbone, and argues that it was strengthened with the reform. It states that the system was designed on the basis of elements that have a clear correlation with the neoliberal ideology, which are the notion of individual responsibility for social security, the preference of private companies as the administrator of savings and benefits, and capitalization in the financial market, without social purposes. It argues that the pension system also incorporates from its origin, elements that collide significantly with neoliberal ideas and that are, fundamentally, the coercive nature of savings, and others that derive from it. It concludes that the reform does not produce a structural modification to the Chilean pension system, despite its great magnitude and the various institutional novelties it incorporates, and, consequently, the system maintains its theoretical identity.},
  langid = {spanish},
  keywords = {afiliacion,capitalizacion individual,neoliberalismo,propiedad del ahorro previsional,Sistema de Pensiones}
}
