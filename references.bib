@incollection{davis_principles_2001,
  title = {Some {{Principles}} of {{Stratification}}},
  booktitle = {Social {{Stratification}}, {{Class}}, {{Race}}, and {{Gender}} in {{Sociological Perspective}}, {{Second Edition}}},
  author = {Davis, Kingsley and Moore, Wilbert E.},
  year = 2001,
  edition = {2},
  publisher = {Routledge},
  abstract = {In a previous paper some concepts for handling the phenomena of social inequality were presented.                               1                             In the present paper a further step in stratification theory is undertaken---an attempt to show the relationship between stratification and the rest of the social order.                               2                             Starting from the proposition that no society is ``classless,'' or unstratified, an effort is made to explain, in functional terms, the universal necessity which calls forth stratification in any social system. Next, an attempt is made to explain the roughly uniform distribution of prestige as between the major types of positions in every society. Since, however, there occur between one society and another great differences in the degree and kind of stratification, some attention is also given to the varieties of social inequality and the variable factors that give rise to them.}
