@article{laenen_why_2019,
  title = {Why Deservingness Theory Needs Qualitative Research: {{Comparing}} Focus Group Discussions on Social Welfare in Three Welfare Regimes},
  shorttitle = {Why Deservingness Theory Needs Qualitative Research},
  author = {Laenen, Tijs and Rossetti, Federica and {van Oorschot}, Wim},
  year = 2019,
