@article{barozet_fluctuaciones_2025/dec./31,
  title = {{Las fluctuaciones de los modelos de justicia social de la izquierda chilena, entre las demandas de garant\'ia de derechos y el ejercicio del poder (1990-2025)}},
  author = {Barozet, Emmanuelle},
  year = {2025/d\'ec./31},
  journal = {Cahiers des Am\'eriques latines},
  number = {107},
  publisher = {Institut des hautes \'etudes de l'Am\'erique latine},
  issn = {1141-7161},
  doi = {10.4000/15qy7},
  urldate = {2026-05-19},
  abstract = {El texto describe la evoluci\'on de las concepciones de justicia social en Chile desde la transici\'on democr\'atica. Hasta la d\'ecada de 2000, la atenci\'on se centr\'o en el crecimiento econ\'omico y la lucha contra la pobreza. A partir de los a\~nos 2010, ante el agotamiento del modelo econ\'omico, los movimientos sociales impusieron un nuevo concepto basado en la repolitizaci\'on de las desigualdades econ\'omicas y la reivindicaci\'on de derechos sociales universales. La pandemia del Covid-19 socav\'o entonces este nuevo consenso reavivando la crisis y la inseguridad. Este art\'iculo examina c\'omo las izquierdas partidistas y extrapartidistas respondieron a estas demandas de justicia social y los retos a los que se enfrentaron, centr\'andose en tres aspectos: la formulaci\'on de derechos sociales, la implementaci\'on de programas pol\'iticos y la recepci\'on de estas pol\'iticas por parte de la sociedad chilena. El an\'alisis se basa en proyectos recientes que incluyen casi doscientas entrevistas con diversos actores pol\'iticos y sociales.},
  copyright = {https://creativecommons.org/licenses/by-nc-nd/4.0/},
  langid = {spanish},
  keywords = {Chile,derechos,justicia social,movimientos sociales,partidos de izquierda,partidos politicos}
}
